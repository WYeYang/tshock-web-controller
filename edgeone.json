{
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*",
      "has": [
        {
          "type": "header",
          "key": "X-TShock-Url"
        }
      ]
    }
  ]
}
